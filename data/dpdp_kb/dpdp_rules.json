      },
      {
        "signal_id": "S2",
        "field": "guardian_consent_id",
        "operator": "is_null",
        "value": null,
        "weight": 0.40,
        "description": "No guardian consent record linked to this minor's account"
      },
      {
        "signal_id": "S3",
        "field": "consent_status",
        "operator": "not_in",
        "value": ["active"],
        "weight": 0.20,
        "description": "Consent on file is not in active state even if a record exists"
      }
    ],
    "violation_threshold": 0.40,
    "risk_threshold": 0.20,
    "recurrence_bonus": 0.25,
    "enabled": true
  },
  {
    "rule_id": "DPDP-006",
    "clause_id": "DPDP-006",
    "rule_name": "Unauthorised Third-Party Data Sharing",
    "dpdp_section": "Section 6",
    "description": "Personal data shared with a third party without specific consent or a valid Data Processing Agreement.",
    "severity": "HIGH",
    "risk_weight": 0.9,
    "check_type": "weighted_evidence",
    "assigned_agent": "risk_agent",
    "primary_table": "transaction_events",
    "join_tables": ["consent_records", "system_inventory"],
    "join_key": "consent_id",
    "evidence_signals": [
      {
        "signal_id": "S1",
        "field": "shared_with_third_party",
        "operator": "equals",
        "value": true,
        "weight": 0.30,
        "description": "Data was shared with a third party in this event"
      },
      {
        "signal_id": "S2",
        "field": "consented_purpose",
        "operator": "not_contains",
        "value": "third_party_sharing",
        "weight": 0.35,
        "description": "Consent scope does not include sharing with third parties"
      },
      {
        "signal_id": "S3",
        "field": "dpa_signed",
        "operator": "equals",
        "value": false,
        "weight": 0.25,
        "description": "No signed Data Processing Agreement on file for the receiving processor"
      },
      {
        "signal_id": "S4",
        "field": "is_cross_border",
        "operator": "equals",
        "value": true,
        "weight": 0.10,
        "description": "Transfer is cross-border — additional DPDP Chapter V obligations apply"
      }
    ],
    "violation_threshold": 0.55,
    "risk_threshold": 0.30,
    "recurrence_bonus": 0.20,
    "enabled": true
  },
  {
    "rule_id": "DPDP-007",
    "clause_id": "DPDP-007",
    "rule_name": "Data Minimisation Violation",
    "dpdp_section": "Section 4",
    "description": "More personal data categories collected or accessed than necessary for the stated purpose.",
    "severity": "MEDIUM",
    "risk_weight": 0.5,
    "check_type": "weighted_evidence",
    "assigned_agent": "regulation_agent",
    "primary_table": "access_logs",
    "join_tables": ["system_inventory"],
    "join_key": "system_id",
    "evidence_signals": [
      {
        "signal_id": "S1",
        "field": "data_volume_accessed",
        "operator": "in",
        "value": ["high", "bulk"],
        "weight": 0.45,
        "description": "Data volume accessed is disproportionately large relative to stated purpose"
      },
      {
        "signal_id": "S2",
        "field": "pii_stored",
        "operator": "equals",
        "value": true,
        "weight": 0.30,
        "description": "System stores PII categories beyond what the declared processing purpose requires"
      },
      {
        "signal_id": "S3",
        "field": "access_reason",
        "operator": "not_matches",
        "value": "processing_purpose",
        "weight": 0.25,
        "description": "Stated access reason does not align with the processing purpose for this data category"
      }
    ],
    "violation_threshold": 0.55,
    "risk_threshold": 0.30,
    "recurrence_bonus": 0.10,
    "enabled": true
  },
  {
    "rule_id": "DPDP-008",
