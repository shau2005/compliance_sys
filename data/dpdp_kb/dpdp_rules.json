[
  {
    "rule_id": "DPDP-001",
    "clause_id": "DPDP-001",
    "rule_name": "Invalid or Missing Consent Before Processing",
    "dpdp_section": "Section 6(1)",
    "description": "Personal data processed without valid, unexpired, purpose-matched consent.",
    "severity": "HIGH",
    "risk_weight": 0.9,
    "check_type": "weighted_evidence",
    "assigned_agent": "regulation_agent",
    "primary_table": "consent_records",
    "join_tables": ["transaction_events"],
    "join_key": "consent_id",
    "evidence_signals": [
      {
        "signal_id": "S1",
        "field": "consent_status",
        "operator": "in",
        "value": ["expired", "revoked", "withdrawn"],
        "weight": 0.40,
        "description": "Consent not in a valid active state at time of processing"
      },
      {
        "signal_id": "S2",
        "field": "expiry_timestamp",
        "operator": "less_than",
        "value": "processing_timestamp",
        "weight": 0.30,
        "description": "Consent expiry date is before the processing event timestamp"
      },
      {
        "signal_id": "S3",
        "field": "consented_purpose",
        "operator": "not_matches",
        "value": "processing_purpose",
        "weight": 0.20,
        "description": "Processing purpose does not match the purpose for which consent was obtained"
      },
      {
        "signal_id": "S4",
        "field": "is_bundled",
        "operator": "equals",
        "value": true,
        "weight": 0.10,
        "description": "Consent was bundled with T&Cs — void under Section 6(2)"
      }
    ],
    "violation_threshold": 0.60,
    "risk_threshold": 0.35,
    "recurrence_bonus": 0.20,
    "enabled": true
  },
  {
    "rule_id": "DPDP-002",
    "clause_id": "DPDP-002",
    "rule_name": "Processing Beyond Stated Purpose",
    "dpdp_section": "Section 5",
    "description": "Personal data used for a purpose beyond what was stated in the notice and consented to.",
    "severity": "HIGH",
    "risk_weight": 0.85,
    "check_type": "weighted_evidence",
    "assigned_agent": "regulation_agent",
    "primary_table": "transaction_events",
    "join_tables": ["consent_records"],
    "join_key": "consent_id",
    "evidence_signals": [
      {
        "signal_id": "S1",
        "field": "consented_purpose",
        "operator": "not_matches",
        "value": "processing_purpose",
        "weight": 0.50,
        "description": "Processing purpose directly contradicts the consented purpose"
      },
      {
        "signal_id": "S2",
        "field": "consent_version",
        "operator": "is_outdated",
        "value": "current_policy_version",
        "weight": 0.30,
        "description": "Consent was given against an outdated policy version — purpose scope may have changed"
      },
      {
        "signal_id": "S3",
        "field": "notice_provided",
        "operator": "equals",
        "value": false,
        "weight": 0.20,
        "description": "No notice was provided specifying the processing purpose before consent"
      }
    ],
    "violation_threshold": 0.50,
    "risk_threshold": 0.30,
    "recurrence_bonus": 0.20,
    "enabled": true
  },
  {
    "rule_id": "DPDP-003",
    "clause_id": "DPDP-003",
    "rule_name": "Retention Beyond Allowed Period",
    "dpdp_section": "Section 8(7)",
    "description": "Personal data retained after its retention expiry date without a legal hold.",
    "severity": "HIGH",
    "risk_weight": 0.8,
    "check_type": "weighted_evidence",
    "assigned_agent": "audit_agent",
    "primary_table": "data_lifecycle",
    "join_tables": [],
    "join_key": null,
    "evidence_signals": [
      {
        "signal_id": "S1",
        "field": "retention_expiry_date",
        "operator": "less_than_today",
        "value": null,
        "weight": 0.45,
        "description": "Retention expiry date has passed — data should have been deleted"
      },
      {
        "signal_id": "S2",
        "field": "retention_status",
        "operator": "in",
        "value": ["expired", "pending_deletion"],
        "weight": 0.30,
        "description": "Retention status indicates data is past its allowed window"
      },
      {
        "signal_id": "S3",
        "field": "legal_hold_flag",
        "operator": "equals",
        "value": false,
        "weight": 0.25,
        "description": "No legal hold is in place to justify extended retention"
      }
    ],
    "violation_threshold": 0.55,
    "risk_threshold": 0.30,
    "recurrence_bonus": 0.15,
    "enabled": true
  },
  {
    "rule_id": "DPDP-004",
    "clause_id": "DPDP-004",
    "rule_name": "Missing Notice to Data Principal",
    "dpdp_section": "Section 5",
