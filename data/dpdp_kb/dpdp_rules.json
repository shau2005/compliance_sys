      }
    ],
    "violation_threshold": 0.60,
    "risk_threshold": 0.30,
    "recurrence_bonus": 0.10,
    "enabled": true
  },
  {
    "rule_id": "DPDP-005",
    "clause_id": "DPDP-005",
    "rule_name": "Children's Data Without Guardian Consent",
    "dpdp_section": "Section 9(1)",
    "description": "Personal data of a minor processed without verifiable parental or guardian consent.",
    "severity": "CRITICAL",
    "risk_weight": 1.0,
    "check_type": "weighted_evidence",
    "assigned_agent": "regulation_agent",
    "primary_table": "customer_master",
    "join_tables": ["consent_records"],
    "join_key": "customer_id",
    "evidence_signals": [
      {
        "signal_id": "S1",
        "field": "is_minor",
        "operator": "equals",
        "value": true,
        "weight": 0.40,
