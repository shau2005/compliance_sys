    "primary_table": "consent_records",
    "join_tables": [],
    "join_key": null,
    "evidence_signals": [
      {
        "signal_id": "S1",
        "field": "notice_provided",
        "operator": "equals",
        "value": false,
        "weight": 0.60,
        "description": "No notice was provided to the Data Principal before data collection"
      },
      {
        "signal_id": "S2",
        "field": "consent_channel",
        "operator": "in",
        "value": ["implicit", "pre_ticked", "inferred"],
        "weight": 0.40,
